{
  "installCommand": "npm install",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/consolidated.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/consolidated.js": {
      "runtime": "@vercel/node@3.0.7"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/consolidated?endpoint=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}